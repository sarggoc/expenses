<%- include('partials/header') %>

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title"><i class="fa-solid fa-route" style="color: var(--primary);"></i> Mileage &amp; <span>GPS Trip Tracker</span></h1>
        <p class="admin-page-sub">Track business vehicle trips via GPS or odometer readings and claim CRA mileage reimbursements ($0.68/km).</p>
    </div>
    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
        <span class="badge" style="background: var(--primary-light); color: var(--primary); font-size: 0.85rem; font-weight: 700; padding: 0.4rem 0.75rem; border-radius: 6px;">
            CRA Mileage Rate: $0.68 / km
        </span>
    </div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-error">
    <i class="fa-solid fa-circle-exclamation"></i><span><%= decodeURIComponent(error) %></span>
</div>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
<div class="alert alert-success">
    <i class="fa-solid fa-circle-check"></i><span><%= decodeURIComponent(success) %></span>
</div>
<% } %>

<div class="dashboard-layout" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
    
    <!-- ═══ LIVE GPS TRACKER WIDGET ═══ -->
    <div class="panel" style="border-top: 4px solid var(--primary);">
        <div class="panel-header">
            <h2 class="panel-title"><i class="fa-solid fa-location-crosshairs"></i> Live GPS Trip Tracker</h2>
        </div>
        <div class="panel-body" style="text-align: center; padding: 1.5rem;">
            <div id="gpsStatusDisplay" style="font-size: 2.2rem; font-weight: 800; color: var(--primary); margin-bottom: 0.25rem;">
                0.00 <span style="font-size: 1rem; color: var(--text-muted); font-weight: 600;">km</span>
            </div>
            <div id="gpsEstReimb" style="font-size: 0.9rem; font-weight: 700; color: #27ae60; margin-bottom: 1.25rem;">
                Estimated Claim: $0.00
            </div>

            <form id="mileageForm" action="/mileage/save" method="POST" autocomplete="off">
                <input type="hidden" name="distance_km" id="hidden_distance_km" value="0">
                <div class="form-group" style="text-align: left;">
                    <label for="trip_name">Trip Purpose / Title <span class="req">*</span></label>
                    <input type="text" id="trip_name" name="trip_name" required placeholder="e.g. Travel to Client Site B" style="width: 100%;">
                </div>

                <div style="display: flex; gap: 0.75rem; justify-content: center; margin-top: 1rem;">
                    <button type="button" id="btnStartGps" class="btn btn-accent btn-sm" onclick="startGpsTracker()" style="flex: 1; height: 42px;">
                        <i class="fa-solid fa-play"></i> Start GPS Tracking
                    </button>
                    <button type="button" id="btnStopGps" class="btn btn-outline btn-sm" onclick="stopGpsTracker()" style="flex: 1; height: 42px;" disabled>
                        <i class="fa-solid fa-stop"></i> Stop &amp; Save
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- ═══ MANUAL ODOMETER LOG ENTRY ═══ -->
    <div class="panel" style="border-top: 4px solid #27ae60;">
        <div class="panel-header">
            <h2 class="panel-title"><i class="fa-solid fa-gauge-high"></i> Manual Distance Entry</h2>
        </div>
        <div class="panel-body" style="padding: 1.25rem;">
            <form action="/mileage/save" method="POST" autocomplete="off">
                <div class="form-group">
                    <label for="manual_trip_name">Trip Purpose / Description <span class="req">*</span></label>
                    <input type="text" id="manual_trip_name" name="trip_name" required placeholder="e.g. Job #104 Site Visit">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="manual_distance_km">Distance Driven (km) <span class="req">*</span></label>
                        <input type="number" step="0.1" id="manual_distance_km" name="distance_km" required placeholder="e.g. 45.5" oninput="calcManualEst(this.value)">
                    </div>
                    <div class="form-group">
                        <label>Reimbursement Claim</label>
                        <div id="manualEstClaim" style="padding: 0.55rem; background: var(--surface-2); border-radius: 6px; border: 1px solid var(--border); font-weight: 700; color: #27ae60; text-align: center;">
                            $0.00
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-sm btn-full" style="margin-top: 0.5rem;">
                    <i class="fa-solid fa-plus"></i> Submit Mileage Claim
                </button>
            </form>
        </div>
    </div>
</div>

<!-- ═══ RECENT TRIPS TABLE ═══ -->
<div class="panel">
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
        <h2 class="panel-title"><i class="fa-solid fa-list-check"></i> My Mileage Log History</h2>
        <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;"><%= (mileageLogs || []).length %> trip(s) logged</span>
    </div>
    <div class="panel-body" style="padding: 0;">
        <div class="table-wrap">
            <table class="spending-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Trip Purpose</th>
                        <th>Distance (km)</th>
                        <th>Rate ($/km)</th>
                        <th>Claim Total ($)</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (mileageLogs && mileageLogs.length > 0) { %>
                        <% mileageLogs.forEach(m => { %>
                            <tr>
                                <td><%= (m.created_at || '').toString().split('T')[0] %></td>
                                <td><strong><%= m.trip_name %></strong></td>
                                <td><%= parseFloat(m.distance_km || 0).toFixed(1) %> km</td>
                                <td>$<%= parseFloat(m.rate_per_km || 0.68).toFixed(2) %></td>
                                <td style="font-weight: 700; color: #27ae60;">$<%= parseFloat(m.total_amount || 0).toFixed(2) %></td>
                                <td>
                                    <span class="badge badge-pending"><%= m.status || 'pending' %></span>
                                </td>
                                <td>
                                    <form action="/mileage/delete/<%= m.id %>" method="POST" onsubmit="return confirm('Delete this trip log?')">
                                        <button type="submit" class="btn btn-outline btn-sm" style="color: var(--danger); padding: 0.2rem 0.5rem;" title="Delete Log">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 2rem; color: var(--text-muted);">No mileage trips logged yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
let watchId = null;
let lastLat = null;
let lastLng = null;
let totalDistMeters = 0;

function calcManualEst(kmVal) {
    const km = parseFloat(kmVal) || 0;
    const claim = km * 0.68;
    const estDiv = document.getElementById('manualEstClaim');
    if (estDiv) estDiv.textContent = '$' + claim.toFixed(2);
}

function getHaversineDistance(lat1, lon1, lat2, lon2) {
    const R = 6371e3;
    const φ1 = lat1 * Math.PI / 180;
    const φ2 = lat2 * Math.PI / 180;
    const Δφ = (lat2 - lat1) * Math.PI / 180;
    const Δλ = (lon2 - lon1) * Math.PI / 180;

    const a = Math.sin(Δφ/2) * Math.sin(Δφ/2) +
              Math.cos(φ1) * Math.cos(φ2) *
              Math.sin(Δλ/2) * Math.sin(Δλ/2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    return R * c;
}

function startGpsTracker() {
    if (!('geolocation' in navigator)) {
        alert('GPS Geolocation is not supported on this device/browser.');
        return;
    }

    document.getElementById('btnStartGps').disabled = true;
    document.getElementById('btnStopGps').disabled = false;
    totalDistMeters = 0;
    lastLat = null;
    lastLng = null;

    watchId = navigator.geolocation.watchPosition(function(pos) {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        if (lastLat !== null && lastLng !== null) {
            const dist = getHaversineDistance(lastLat, lastLng, lat, lng);
            if (dist > 5) {
                totalDistMeters += dist;
            }
        }
        lastLat = lat;
        lastLng = lng;

        const totalKm = (totalDistMeters / 1000).toFixed(2);
        document.getElementById('gpsStatusDisplay').innerHTML = totalKm + ' <span style="font-size: 1rem; color: var(--text-muted); font-weight: 600;">km</span>';
        document.getElementById('gpsEstReimb').textContent = 'Estimated Claim: $' + (totalKm * 0.68).toFixed(2);
        document.getElementById('hidden_distance_km').value = totalKm;
    }, function(err) {
        console.warn('GPS Error:', err);
    }, {
        enableHighAccuracy: true,
        maximumAge: 1000
    });
}

function stopGpsTracker() {
    if (watchId !== null) {
        navigator.geolocation.clearWatch(watchId);
        watchId = null;
    }
    const finalKm = parseFloat(document.getElementById('hidden_distance_km').value) || 0;
    if (finalKm <= 0) {
        alert('No distance recorded during this trip.');
        document.getElementById('btnStartGps').disabled = false;
        document.getElementById('btnStopGps').disabled = true;
        return;
    }
    document.getElementById('mileageForm').submit();
}
</script>

<%- include('partials/footer') %>
