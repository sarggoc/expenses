        </main>

        <% if (user) { %>
        <!-- Mobile Bottom Navigation Bar -->
        <div class="mobile-bottom-nav">
            <!-- Home Tab -->
            <a href="/dashboard" class="mobile-nav-item <%= (locals.activePage === 'dashboard' && (locals.activeView === 'history' || !locals.activeView)) ? 'active' : '' %>">
                <i class="fa-solid fa-house"></i>
                <span>Home</span>
            </a>

            <!-- Gas or Reports/Limits Tab -->
            <% if (user.role === 'admin' || user.role === 'accounting' || user.role === 'approver') { %>
                <a href="/admin/reports" class="mobile-nav-item <%= locals.activePage === 'reports' ? 'active' : '' %>">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                    <span>Reports</span>
                </a>
            <% } else if (locals.hasGasCard) { %>
                <a href="/gas-expenses?view=history" class="mobile-nav-item <%= locals.activePage === 'gas-expenses' ? 'active' : '' %>">
                    <i class="fa-solid fa-gas-pump"></i>
                    <span>Gas</span>
                </a>
            <% } else { %>
                <a href="/dashboard?view=account" class="mobile-nav-item <%= (locals.activePage === 'dashboard' && locals.activeView === 'account') ? 'active' : '' %>">
                    <i class="fa-solid fa-user-gear"></i>
                    <span>Limits</span>
                </a>
            <% } %>

            <!-- Add Button Tab (Triggers Drawer) -->
            <button type="button" class="mobile-nav-item mobile-nav-add-btn" id="mobileAddBtn">
                <div class="add-icon-wrapper">
                    <i class="fa-solid fa-plus"></i>
                </div>
                <span>File Claim</span>
            </button>

            <!-- Notifications Tab -->
            <button type="button" class="mobile-nav-item" id="mobileNotifTabBtn" style="position: relative;">
                <i class="fa-solid fa-bell"></i>
                <span>Alerts</span>
                <% if (locals.unreadNotificationsCount > 0) { %>
                    <span class="mobile-notif-badge"><%= locals.unreadNotificationsCount %></span>
                <% } %>
            </button>

            <!-- Direct Logout Tab -->
            <a href="/logout" class="mobile-nav-item" style="color: var(--danger, #e74c3c);">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>

        <!-- Mobile Bottom Slide-up Drawer for Add Actions -->
        <div class="mobile-drawer-overlay" id="mobileDrawerOverlay">
            <div class="mobile-drawer" id="mobileDrawer">
                <div class="mobile-drawer-handle"></div>
                <div class="mobile-drawer-header">
                    <h3>New Expense Claim</h3>
                    <button class="mobile-drawer-close" id="mobileDrawerCloseBtn"><i class="fa-solid fa-xmark"></i></button>
                </div>
                <div class="mobile-drawer-body">
                    <a href="/dashboard?view=add-reimb" class="drawer-action-item">
                        <div class="action-icon reimb"><i class="fa-solid fa-hand-holding-dollar"></i></div>
                        <div class="action-details">
                            <span class="action-title">Add Reimbursement</span>
                            <span class="action-desc">Out-of-pocket cash or personal card expense</span>
                        </div>
                    </a>
                    <% if (user.card_last_digits && user.card_last_digits !== 'None') { %>
                        <a href="/dashboard?view=add-cc" class="drawer-action-item">
                            <div class="action-icon cc"><i class="fa-solid fa-credit-card"></i></div>
                            <div class="action-details">
                                <span class="action-title">Add Credit Card Expense</span>
                                <span class="action-desc">Transactions on your company credit card</span>
                            </div>
                        </a>
                    <% } %>
                    <% if (locals.hasGasCard) { %>
                        <a href="/gas-expenses?view=add-form" class="drawer-action-item">
                            <div class="action-icon gas"><i class="fa-solid fa-gas-pump"></i></div>
                            <div class="action-details">
                                <span class="action-title">Add Gas Expense</span>
                                <span class="action-desc">Fuel transactions with vehicle job tracking</span>
                            </div>
                        </a>
                    <% } %>
                    <a href="/mileage" class="drawer-action-item">
                        <div class="action-icon" style="background: #EBF5FB; color: #2980b9;"><i class="fa-solid fa-route"></i></div>
                        <div class="action-details">
                            <span class="action-title">GPS Mileage Tracker</span>
                            <span class="action-desc">Track vehicle trip distance ($0.68/km)</span>
                        </div>
                    </a>
                    <button type="button" onclick="requestMobilePushPermission()" class="drawer-action-item" style="border: none; background: var(--surface-2); cursor: pointer; text-align: left; width: 100%;">
                        <div class="action-icon" style="background: #FEF9E7; color: #f39c12;"><i class="fa-solid fa-bell"></i></div>
                        <div class="action-details">
                            <span class="action-title">Enable Push Notifications</span>
                            <span class="action-desc">Receive instant Android approval alerts</span>
                        </div>
                    </button>
                    <button type="button" onclick="setupBiometricUnlock()" class="drawer-action-item" style="border: none; background: var(--surface-2); cursor: pointer; text-align: left; width: 100%;">
                        <div class="action-icon" style="background: #F4ECF7; color: #8e44ad;"><i class="fa-solid fa-fingerprint"></i></div>
                        <div class="action-details">
                            <span class="action-title">Setup FaceID / Fingerprint</span>
                            <span class="action-desc">Fast biometric login on your phone</span>
                        </div>
                    </button>
                </div>
            </div>
        </div>
        <% } %>

        <footer>
            &copy; <%= new Date().getFullYear() %> Sargtech Technologies &mdash; Expense Reporting Platform &mdash; All data encrypted and securely stored.
        </footer>
    </div><!-- /.main-wrapper -->

</div><!-- /.app-shell -->

<script src="/js/app.js"></script>
<script>
// ── Theme toggle
const root     = document.documentElement;
const toggleBtn = document.getElementById('themeToggle');
const themeIcon = document.getElementById('themeIcon');
const themeLabel = document.getElementById('themeLabel');

function applyTheme(t) {
    root.setAttribute('data-theme', t);
    localStorage.setItem('sargtech-theme', t);
    if (themeIcon) {
        themeIcon.className = t === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
    }
    if (themeLabel) themeLabel.textContent = t === 'dark' ? 'Dark' : 'Light';
}

// Init from saved
applyTheme(localStorage.getItem('sargtech-theme') || 'light');

if (toggleBtn) {
    toggleBtn.addEventListener('click', () => {
        const current = root.getAttribute('data-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
    });
}

// Notifications toggle
const notifToggle = document.getElementById('notif-toggle');
const notifModal = document.getElementById('notificationsModal');
const notifClose = document.getElementById('notifClose');

if (notifToggle && notifModal) {
    notifToggle.addEventListener('click', (e) => {
        e.preventDefault();
        notifModal.classList.add('open');
        document.body.style.overflow = 'hidden';
    });
}

function closeNotifModal() {
    if (notifModal) {
        notifModal.classList.remove('open');
        document.body.style.overflow = '';
    }
}

if (notifClose) notifClose.addEventListener('click', closeNotifModal);
if (notifModal) notifModal.addEventListener('click', e => { if (e.target === notifModal) closeNotifModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeNotifModal(); });

// ── Mobile Bottom Navigation & Slide-up Drawer Controls
const mobileAddBtn = document.getElementById('mobileAddBtn');
const mobileDrawerOverlay = document.getElementById('mobileDrawerOverlay');
const mobileDrawerCloseBtn = document.getElementById('mobileDrawerCloseBtn');

if (mobileAddBtn && mobileDrawerOverlay) {
    mobileAddBtn.addEventListener('click', () => {
        mobileDrawerOverlay.classList.add('open');
    });
}

function closeMobileDrawer() {
    if (mobileDrawerOverlay) {
        mobileDrawerOverlay.classList.remove('open');
    }
}

if (mobileDrawerCloseBtn) mobileDrawerCloseBtn.addEventListener('click', closeMobileDrawer);
if (mobileDrawerOverlay) mobileDrawerOverlay.addEventListener('click', (e) => {
    if (e.target === mobileDrawerOverlay) closeMobileDrawer();
});

// Alerts button on mobile bottom nav
const mobileNotifTabBtn = document.getElementById('mobileNotifTabBtn');
if (mobileNotifTabBtn && notifModal) {
    mobileNotifTabBtn.addEventListener('click', () => {
        notifModal.classList.add('open');
        document.body.style.overflow = 'hidden';
    });
}

// Menu button on mobile bottom nav (opens main sidebar)
const mobileMenuTabBtn = document.getElementById('mobileMenuTabBtn');
const sidebar = document.getElementById('sidebar');
const sidebarOverlay = document.getElementById('sidebarOverlay');
if (mobileMenuTabBtn && sidebar && sidebarOverlay) {
    mobileMenuTabBtn.addEventListener('click', () => {
        sidebar.classList.add('open');
        sidebarOverlay.classList.add('open');
    });
}
</script>
</body>
</html>
