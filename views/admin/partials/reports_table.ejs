<div style="padding: 0.75rem 1rem; background: var(--surface); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
    <div style="display: flex; align-items: center; gap: 0.5rem; flex: 1; min-width: 250px;">
        <i class="fa-solid fa-magnifying-glass" style="color: var(--text-muted); font-size: 0.85rem;"></i>
        <input type="text" id="reportTableSearch" placeholder="Filter store, job #, txn ID, user, amount..." onkeyup="filterReportTable()" style="padding: 0.4rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; font-size: 0.85rem; width: 100%; max-width: 320px; outline: none;">
    </div>
    <form id="batchActionForm" action="/admin/expenses/batch-status" method="POST" style="display: none; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
        <input type="hidden" name="expense_ids" id="batchExpenseIds">
        <input type="hidden" name="status" id="batchActionStatus">
        <span id="selectedCountBadge" class="badge" style="background: var(--primary); color: #fff; font-weight: 700; font-size: 0.78rem; padding: 0.3rem 0.6rem;">0 selected</span>
        <button type="button" class="btn btn-accent btn-sm" onclick="submitBatchAction('approved')" style="font-size: 0.78rem;">
            <i class="fa-solid fa-check-double"></i> Approve Selected
        </button>
        <button type="button" class="btn btn-sm" style="background: var(--danger-light); color: var(--danger); border: none; font-size: 0.78rem;" onclick="submitBatchAction('rejected')">
            <i class="fa-solid fa-xmark"></i> Reject Selected
        </button>
    </form>
</div>

<div class="table-wrap">
    <table class="report-table" id="adminReportTable">
        <thead>
            <tr>
                <th style="width: 38px; text-align: center;"><input type="checkbox" id="selectAllExpenses" onclick="toggleSelectAllExpenses(this)" title="Select all pending expenses"></th>
                <th>Date</th>
                <th>Store / Vendor</th>
                <th>Origin</th>
                <th>Job #</th>
                <th>Supervisor</th>
                <th>Net Amount</th>
                <th>Tax</th>
                <th>Total</th>
                <th>Receipt</th>
                <th>Status</th>
                <th style="text-align: right;">Action</th>
            </tr>
        </thead>
        <tbody>
            <% tableExpenses.forEach(exp => { %>
            <tr>
                <td style="text-align: center;">
                    <% if (exp.status === 'pending') { %>
                        <input type="checkbox" class="expense-select-cb" value="<%= exp.id %>" onclick="updateBatchSelection()">
                    <% } else { %>
                        <span style="color:var(--text-light); font-size:0.75rem;">—</span>
                    <% } %>
                </td>
                <td><%= (exp.date || '').toString().split('T')[0] %></td>
                <td>
                    <strong><%= exp.store_name %></strong>
                    <div class="cell-sub">ID: <%= exp.transaction_id %></div>
                    <% if (exp.description) { %>
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.35rem; max-width: 250px; white-space: normal; word-break: break-word;">
                            <i class="fa-solid fa-align-left" style="font-size: 0.7rem;"></i> <%= exp.description %>
                        </div>
                    <% } %>
                </td>
                <td>
                    <% if (exp.submission_method) { %>
                        <% if (exp.submission_method === 'Credit Card') { %>
                        <% if (exp.submission_method === 'Company Credit Card' || exp.payment_type === 'Company Card') { %>
                            <span class="badge" style="background: rgba(0, 120, 215, 0.1); color: #0078d7; border: 1px solid rgba(0, 120, 215, 0.2); font-size: 0.72rem; padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 600;">
                                <i class="fa-solid fa-credit-card"></i> Credit Card <%= (exp.user_card_digits || exp.card_last_digits || (typeof user !== 'undefined' && user.card_last_digits)) ? `(**** ${exp.user_card_digits || exp.card_last_digits || user.card_last_digits})` : '' %>
                            </span>
                        <% } else if (exp.submission_method === 'Gas/Fuel Card') { %>
                            <span class="badge" style="background: rgba(230, 126, 34, 0.1); color: #e67e22; border: 1px solid rgba(230, 126, 34, 0.25); font-size: 0.72rem; padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 600;"><i class="fa-solid fa-gas-pump"></i> Gas Card</span>
                        <% } else { %>
                            <span class="badge" style="background: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid rgba(46, 204, 113, 0.25); font-size: 0.72rem; padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 600;"><i class="fa-solid fa-hand-holding-dollar"></i> Reimbursement</span>
                        <% } %>
                    <% } else { %>
                        <% if (exp.payment_type === 'Company Card') { %>
                            <span class="badge" style="background: rgba(0, 120, 215, 0.1); color: #0078d7; border: 1px solid rgba(0, 120, 215, 0.2); font-size: 0.72rem; padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 600;">
                                <i class="fa-solid fa-credit-card"></i> Credit Card <%= (exp.user_card_digits || exp.card_last_digits || (typeof user !== 'undefined' && user.card_last_digits)) ? `(**** ${exp.user_card_digits || exp.card_last_digits || user.card_last_digits})` : '' %>
                            </span>
                        <% } else { %>
                            <span class="badge" style="background: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid rgba(46, 204, 113, 0.25); font-size: 0.72rem; padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 600;"><i class="fa-solid fa-hand-holding-dollar"></i> Reimbursement</span>
                        <% } %>
                    <% } %>
                </td>
                <td>
                    <span class="badge badge-none" style="font-weight: 600;"><%= exp.job_number || '—' %></span>
                    <% if (exp.job_number && typeof pendingJobsMap !== 'undefined' && pendingJobsMap[exp.job_number.trim().toUpperCase()]) { %>
                        <div style="margin-top: 0.35rem;">
                            <form action="/admin/jobnumbers/confirm/<%= pendingJobsMap[exp.job_number.trim().toUpperCase()] %>" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-sm" style="background: #2ecc71; color: #fff; border: none; padding: 0.2rem 0.45rem; border-radius: 4px; font-weight: 600; cursor: pointer; font-size: 0.65rem; display: inline-flex; align-items: center; gap: 0.2rem; height: auto;" title="Accept and Activate Job Number">
                                    <i class="fa-solid fa-check" style="font-size: 0.6rem;"></i> Accept Job
                                </button>
                            </form>
                        </div>
                    <% } %>
                </td>
                <td><%= exp.supervisor || '—' %></td>
                <td style="font-weight: 600;">$<%= parseFloat(exp.net_amount).toFixed(2) %></td>
                <td>
                    $<%= parseFloat(exp.tax_amount).toFixed(2) %>
                    <div style="margin-top:2px;">
                        <% if (exp.tax_type === 'GST') { %>
                            <span class="badge badge-gst">GST 5%</span>
                        <% } else if (exp.tax_type === 'HST13') { %>
                            <span class="badge badge-hst13">HST 13%</span>
                        <% } else if (exp.tax_type === 'HST15') { %>
                            <span class="badge badge-hst15">HST 15%</span>
                        <% } else { %>
                            <span class="badge badge-none">None</span>
                        <% } %>
                    </div>
                </td>
                <td style="font-weight: 700; color: var(--primary);">$<%= parseFloat(exp.total_amount).toFixed(2) %></td>
                <td>
                    <% if (exp.receipt_photo_path) { %>
                        <div class="receipt-thumbnail-container">
                            <img src="<%= exp.receipt_photo_path %>" class="receipt-thumbnail" onclick="viewReceipt('<%= exp.receipt_photo_path %>')" alt="Receipt" title="Click to enlarge" />
                        </div>
                    <% } else { %>
                        <span style="color: var(--text-light);">—</span>
                    <% } %>
                </td>
                <td>
                    <% if (exp.status === 'approved') { %>
                        <span class="badge" style="background:var(--accent); color:#fff; font-size:.72rem;"><i class="fa-solid fa-circle-check"></i> Approved</span>
                        <% if (exp.payment_type !== 'Company Card') { %>
                            <div style="margin-top: 0.25rem;">
                                <% const pStat = exp.payout_status || 'unpaid'; %>
                                <% if (pStat === 'paid') { %>
                                    <span class="badge" style="background:#2ecc71; color:#fff; font-size:0.65rem; padding:0.15rem 0.35rem;"><i class="fa-solid fa-sack-dollar"></i> Payout: Paid</span>
                                <% } else if (pStat === 'processing') { %>
                                    <span class="badge" style="background:#f39c12; color:#fff; font-size:0.65rem; padding:0.15rem 0.35rem;"><i class="fa-solid fa-spinner"></i> Payout: Processing</span>
                                <% } else { %>
                                    <span class="badge" style="background:var(--text-muted); color:#fff; font-size:0.65rem; padding:0.15rem 0.35rem;"><i class="fa-solid fa-hourglass-start"></i> Payout: Unpaid</span>
                                <% } %>
                            </div>
                        <% } %>
                        <% if (exp.approved_at) { %>
                            <% 
                                let formattedApprovedAt = '';
                                try {
                                    const appDate = new Date(exp.approved_at);
                                    const yyyy = appDate.getFullYear();
                                    const mm = String(appDate.getMonth() + 1).padStart(2, '0');
                                    const dd = String(appDate.getDate()).padStart(2, '0');
                                    const hh = String(appDate.getHours()).padStart(2, '0');
                                    const min = String(appDate.getMinutes()).padStart(2, '0');
                                    formattedApprovedAt = `${yyyy}-${mm}-${dd} ${hh}:${min}`;
                                } catch (e) {
                                    formattedApprovedAt = exp.approved_at;
                                }
                            %>
                            <div style="font-size: 0.68rem; color: var(--text-muted); margin-top: 0.35rem; font-weight: 500; line-height: 1.3;">
                                <div><i class="fa-regular fa-calendar-check" style="font-size: 0.65rem;"></i> <%= formattedApprovedAt %></div>
                                <% if (exp.approved_by_name) { %>
                                    <div style="margin-top: 2px; color: var(--text);"><i class="fa-solid fa-user-shield" style="font-size: 0.65rem; color: var(--accent);"></i> <%= exp.approved_by_name %></div>
                                <% } %>
                            </div>
                        <% } %>
                    <% } else if (exp.status === 'rejected') { %>
                        <span class="badge" style="background:var(--danger); color:#fff; font-size:.72rem;"><i class="fa-solid fa-circle-xmark"></i> Rejected</span>
                        <% if (exp.rejection_reason) { %>
                            <div style="font-size: 0.7rem; color: var(--danger); margin-top: 0.25rem; font-weight: 500; max-width: 150px; white-space: normal; word-break: break-word;">
                                <strong>Reason:</strong> <%= exp.rejection_reason %>
                            </div>
                        <% } %>
                    <% } else { %>
                        <span class="badge" style="background:var(--warning); color:#fff; font-size:.72rem;"><i class="fa-solid fa-clock"></i> Pending</span>
                    <% } %>
                </td>
                <td style="text-align: right;">
                    <!-- Approval actions -->
                    <% if (exp.status === 'pending') { %>
                    <div style="display: inline-flex; gap: 0.35rem; justify-content: flex-end;">
                        <form action="/admin/expense/<%= exp.id %>/status" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="approved">
                            <button type="submit" class="btn btn-accent btn-sm" style="padding: 0.25rem 0.5rem; font-size: 0.72rem;">
                                <i class="fa-solid fa-check"></i> Approve
                            </button>
                        </form>
                        <button type="button" class="btn btn-sm" onclick="openRejectModal('<%= exp.id %>')" style="background:var(--danger-light); color:var(--danger); border:none; padding: 0.25rem 0.5rem; font-size: 0.72rem; cursor: pointer;">
                            <i class="fa-solid fa-xmark"></i> Reject
                        </button>
                    </div>
                        <form action="/admin/expense/<%= exp.id %>/status" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="pending">
                            <button type="submit" class="btn btn-outline btn-sm" style="padding: 0.15rem 0.35rem; font-size: 0.68rem; height: 24px;">
                                Reset to Pending
                            </button>
                        </form>
                        <% if (exp.status === 'approved' && exp.payment_type !== 'Company Card' && typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'accounting')) { %>
                            <div style="margin-top: 0.35rem;">
                                <form action="/admin/expense/<%= exp.id %>/payout-status" method="POST" style="display:inline-flex; align-items:center;">
                                    <select name="payout_status" onchange="this.form.submit()" style="font-size: 0.65rem; padding: 0.15rem 0.3rem; border-radius: 4px; border: 1px solid var(--border); background: var(--surface); color: var(--text); font-weight: 600; cursor: pointer;" title="Update payout status">
                                        <option value="unpaid" <%= (exp.payout_status || 'unpaid') === 'unpaid' ? 'selected' : '' %>>Payout: Unpaid</option>
                                        <option value="processing" <%= exp.payout_status === 'processing' ? 'selected' : '' %>>Payout: Processing</option>
                                        <option value="paid" <%= exp.payout_status === 'paid' ? 'selected' : '' %>>Payout: Paid</option>
                                    </select>
                                </form>
                            </div>
                        <% } %>
                    <% } %>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
function filterReportTable() {
    const input = document.getElementById('reportTableSearch');
    if (!input) return;
    const filter = input.value.toLowerCase();
    const table = document.getElementById('adminReportTable');
    if (!table) return;
    const rows = table.querySelectorAll('tbody tr');
    
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(filter) ? '' : 'none';
    });
}

function updateBatchSelection() {
    const cbs = document.querySelectorAll('.expense-select-cb:checked');
    const ids = Array.from(cbs).map(cb => cb.value);
    const form = document.getElementById('batchActionForm');
    const idsInput = document.getElementById('batchExpenseIds');
    const badge = document.getElementById('selectedCountBadge');

    if (ids.length > 0) {
        if (form) form.style.display = 'inline-flex';
        if (idsInput) idsInput.value = ids.join(',');
        if (badge) badge.textContent = `${ids.length} selected`;
    } else {
        if (form) form.style.display = 'none';
        if (idsInput) idsInput.value = '';
    }
}

function toggleSelectAllExpenses(master) {
    const visibleCbs = document.querySelectorAll('#adminReportTable tbody tr:not([style*="display: none"]) .expense-select-cb');
    visibleCbs.forEach(cb => cb.checked = master.checked);
    updateBatchSelection();
}

function submitBatchAction(status) {
    const statusInput = document.getElementById('batchActionStatus');
    const form = document.getElementById('batchActionForm');
    if (statusInput && form) {
        statusInput.value = status;
        form.submit();
    }
}
</script>
