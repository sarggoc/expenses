<!-- Rejection Reason Modal -->
<div id="rejectModal" class="modal" role="dialog" aria-modal="true" aria-label="Reject Expense">
    <button id="rejectModalClose" class="modal-close" aria-label="Close" onclick="closeRejectModal()"><i class="fa-solid fa-xmark"></i></button>
    <div class="panel" style="width: 100%; max-width: 440px; background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow-lg); overflow: hidden; border: 1px solid var(--border);">
        <div class="panel-header" style="background: var(--danger-light); border-bottom-color: rgba(220,53,69,0.15); padding: 1.25rem;">
            <h2 class="panel-title" style="color: var(--danger); margin: 0; font-size: 1.15rem; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fa-solid fa-triangle-exclamation"></i> Reject Expense Submission
            </h2>
        </div>
        <div class="panel-body" style="padding: 1.5rem;">
            <form id="rejectForm" action="" method="POST" style="margin: 0; padding: 0;">
                <input type="hidden" name="status" value="rejected">
                <div class="form-group" style="margin-bottom: 1.25rem;">
                    <label for="rejection_reason" style="font-weight: 600; font-size: 0.9rem; color: var(--text); display: block; margin-bottom: 0.5rem;">
                        Reason for Rejection <span class="req" style="color: var(--danger);">*</span>
                    </label>
                    <textarea id="rejection_reason" name="rejection_reason" required 
                              placeholder="Please enter a reason for rejecting this expense (e.g. invalid receipt, incorrect job number, tax type mismatch, etc.)." 
                              rows="4" 
                              style="width: 100%; resize: none; padding: 0.75rem; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--background); color: var(--text); font-family: inherit; font-size: 0.88rem; transition: border-color var(--transition); box-sizing: border-box;"></textarea>
                </div>
                <div style="display: flex; gap: 0.75rem; justify-content: flex-end;">
                    <button type="button" class="btn btn-outline btn-sm" onclick="closeRejectModal()" style="height: 38px; padding: 0 1.25rem;">Cancel</button>
                    <button type="submit" class="btn btn-sm" style="background: var(--danger); color: white; border: none; height: 38px; padding: 0 1.25rem; font-weight: 600;">
                        <i class="fa-solid fa-ban"></i> Confirm Rejection
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const rejectModal = document.getElementById("rejectModal");
    const rejectForm = document.getElementById("rejectForm");
    const rejectReasonInput = document.getElementById("rejection_reason");

    window.openRejectModal = function(expenseId) {
        if (rejectForm) {
            rejectForm.action = `/admin/expense/${expenseId}/status`;
        }
        if (rejectReasonInput) {
            rejectReasonInput.value = "";
        }
        if (rejectModal) {
            rejectModal.classList.add("open");
            document.body.style.overflow = "hidden";
            setTimeout(() => {
                rejectReasonInput.focus();
            }, 100);
        }
    };

    window.closeRejectModal = function() {
        if (rejectModal) {
            rejectModal.classList.remove("open");
            document.body.style.overflow = "";
        }
    };

    // Close on escape key
    document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") {
            closeRejectModal();
            closeCsvExportModal();
        }
    });

    // CSV Export Modal logic
    window.openCsvExportModal = function() {
        const csvExportModal = document.getElementById("csvExportModal");
        if (csvExportModal) {
            csvExportModal.classList.add("open");
            document.body.style.overflow = "hidden";
        }
    };
    window.closeCsvExportModal = function() {
        const csvExportModal = document.getElementById("csvExportModal");
        if (csvExportModal) {
            csvExportModal.classList.remove("open");
            document.body.style.overflow = "";
        }
    };
    window.submitCustomCsvExport = function() {
        // Collect checked columns with their sort orders
        const rows = document.querySelectorAll(".csv-col-row");
        const selectedCols = [];
        
        rows.forEach(row => {
            const checkbox = row.querySelector(".csv-col-cb");
            const orderInput = row.querySelector(".csv-col-order");
            if (checkbox && checkbox.checked) {
                selectedCols.push({
                    name: checkbox.value,
                    order: parseInt(orderInput.value) || 99
                });
            }
        });
        
        // Sort by order ascending
        selectedCols.sort((a, b) => a.order - b.order);
        const colString = selectedCols.map(c => c.name).join(",");
        
        if (!colString) {
            alert("Please select at least one column to export.");
            return;
        }
        
        const paymentType = document.getElementById("csv_payment_type").value;
        const url = `/admin/export/csv/<%= selectedUser ? selectedUser.id : '' %>?start_date=<%= startDate %>&end_date=<%= endDate %>&payment_type=${paymentType}&columns=${colString}`;
        
        window.location.href = url;
        closeCsvExportModal();
    };
</script>

<!-- Custom CSV Export Modal -->
<div id="csvExportModal" class="modal" role="dialog" aria-modal="true" aria-label="CSV Export Options">
