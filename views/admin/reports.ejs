                <% 
                    const defaultCols = [
                        { id: 'date', label: 'Date', order: 1 },
                        { id: 'store_name', label: 'Store/Merchant', order: 2 },
                        { id: 'transaction_id', label: 'Transaction ID', order: 3 },
                        { id: 'job_number', label: 'Job Number', order: 4 },
                        { id: 'supervisor', label: 'Supervisor', order: 5 },
                        { id: 'description', label: 'Description', order: 6 },
