                        { id: 'net_amount', label: 'Net Amount ($)', order: 8 },
                        { id: 'tax_type', label: 'Tax Type', order: 9 },
                        { id: 'tax_amount', label: 'Tax Amount ($)', order: 10 },
                        { id: 'fees_breakdown', label: 'Extra Fees Breakdown', order: 11 },
                        { id: 'fees_total', label: 'Extra Fees Total ($)', order: 12 },
                        { id: 'total_amount', label: 'Total Cost ($)', order: 13 },
                        { id: 'status', label: 'Status', order: 14 },
                        { id: 'submitted_at', label: 'Submitted At', order: 15 },
                        { id: 'approved_at', label: 'Approved At', order: 16 },
                        { id: 'approved_by', label: 'Approved By', order: 17 },
                        { id: 'voided_at', label: 'Voided At', order: 18 },
                        { id: 'void_reason', label: 'Void Reason', order: 19 }
                    ];
                %>
                <% defaultCols.forEach(col => { %>
                    <div class="csv-col-row" style="display: flex; align-items: center; justify-content: space-between; padding: 0.35rem 0.5rem; border-bottom: 1px solid var(--border-light); background: #fff; border-radius: 4px;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; font-weight: 500; cursor: pointer; margin: 0;">
                            <input type="checkbox" class="csv-col-cb" value="<%= col.id %>" checked style="cursor: pointer;">
                            <span><%= col.label %></span>
                        </label>
                        <div style="display: flex; align-items: center; gap: 0.4rem;">
                            <span style="font-size: 0.75rem; color: var(--text-muted);">Order:</span>
                            <input type="number" class="csv-col-order" value="<%= col.order %>" min="1" max="99" style="width: 45px; padding: 0.15rem; text-align: center; border: 1px solid var(--border); border-radius: 3px; font-size: 0.75rem;">
                        </div>
                    </div>
                <% }) %>
            </div>
            
            <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
                <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeCsvExportModal()">Cancel</button>
                <button type="button" class="btn btn-accent" style="flex: 2; background: #2ecc71; border-color: #2ecc71;" onclick="submitCustomCsvExport()">
                    <i class="fa-solid fa-file-export"></i> Generate CSV Export
                </button>
            </div>
        </div>
    </div>
</div>

<%
    const allReceipts = [];
    if (locals.expenses && expenses.length > 0) {
        expenses.forEach(e => {
            if (e.receipt_photo_path) {
                allReceipts.push({
                    path: e.receipt_photo_path,
                    title: `${e.date ? e.date.split('T')[0] : ''} - ${e.store_name} ($${parseFloat(e.total_amount).toFixed(2)}) - ${e.payment_type || 'Reimbursement'}`
                });
            }
        });
    }
    if (locals.gasExpenses && gasExpenses.length > 0) {
        gasExpenses.forEach(e => {
            if (e.receipt_photo_path) {
                allReceipts.push({
                    path: e.receipt_photo_path,
                    title: `${e.date ? e.date.split('T')[0] : ''} - ${e.store_name} ($${parseFloat(e.total_amount).toFixed(2)}) - Gas Card`
                });
            }
        });
    }
%>

<% if (allReceipts.length > 0) { %>
    <div class="receipts-print-section">
        <h3 class="receipts-print-title"><i class="fa-solid fa-paperclip"></i> Receipt Attachments</h3>
        <div class="receipts-print-grid">
            <% allReceipts.forEach(r => { %>
                <div class="receipt-print-item">
                    <h4><%= r.title %></h4>
                    <img src="<%= r.path %>" alt="Receipt Image" onclick="viewReceipt('<%= r.path %>')" />
                </div>
            <% }) %>
        </div>
    </div>
<% } %>

