<%- include('../partials/header') %>

<div class="admin-page-header no-print">
    <div>
        <h1 class="admin-page-title"><i class="fa-solid fa-file-invoice-dollar"></i> Expense <span>Reports</span></h1>
        <p class="admin-page-sub">Filter expenses by employee and timeline, approve/reject pending submissions, and export reports to PDF or Excel.</p>
    </div>
</div>

<% if (error) { %>
<div class="alert alert-error">
    <i class="fa-solid fa-circle-exclamation"></i><span><%= decodeURIComponent(error) %></span>
</div>
<% } %>
<% if (success) { %>
<div class="alert alert-success">
    <i class="fa-solid fa-circle-check"></i><span><%= decodeURIComponent(success) %></span>
</div>
<% } %>

<!-- ═══ FILTER BAR ═══ -->
<div class="panel no-print" style="margin-bottom: 1.5rem;">
    <div class="panel-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h2 class="panel-title" style="margin:0;">
            <i class="fa-solid <%= locals.activeView === 'archive' ? 'fa-box-archive' : 'fa-clock' %>"></i>
            <%= locals.activeView === 'archive' ? 'Archive (Approved Expenses)' : 'Submitted Expenses & Approvals' %>
        </h2>
        <div style="display:flex; gap:0.35rem;">
            <a href="/admin/reports?view=submitted" class="btn btn-sm <%= locals.activeView !== 'archive' ? 'btn-primary' : 'btn-outline' %>">
                <i class="fa-solid fa-clock"></i> Submitted Expenses
            </a>
            <a href="/admin/reports?view=archive" class="btn btn-sm <%= locals.activeView === 'archive' ? 'btn-primary' : 'btn-outline' %>">
                <i class="fa-solid fa-box-archive"></i> Archive
            </a>
        </div>
    </div>
    <div class="panel-body">
        <form action="/admin/reports" method="GET" class="filter-bar" style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
            <div class="filter-field" style="min-width: 150px;">
                <label for="report_target">Report Type</label>
                <select id="report_target" name="report_target" onchange="toggleReportFields(this.value)" style="width: 100%; padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px;">
                    <option value="employee" <%= locals.reportTarget === 'employee' ? 'selected' : '' %>>Employee</option>
                    <option value="truck" <%= locals.reportTarget === 'truck' ? 'selected' : '' %>>Truck</option>
                    <option value="group" <%= locals.reportTarget === 'group' ? 'selected' : '' %>>Group</option>
                </select>
            </div>

            <!-- Employee Select Field -->
            <div class="filter-field" id="employee_field" style="flex: 1; min-width: 200px; display: <%= locals.reportTarget === 'employee' || !locals.reportTarget ? 'block' : 'none' %>;">
                <label for="user_id">Select Employee <span class="req">*</span></label>
                <select id="user_id" name="user_id" style="width: 100%; padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px;">
                    <option value="">— Select Employee —</option>
                    <% if (locals.users) { %>
                        <% users.forEach(u => { %>
                            <option value="<%= u.id %>" <%= locals.selectedUser && locals.selectedUser.id == u.id ? 'selected' : '' %>><%= u.first_name %> <%= u.last_name %> (@<%= u.username %>)</option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <!-- Truck Select Field -->
            <div class="filter-field" id="truck_field" style="flex: 1; min-width: 200px; display: <%= locals.reportTarget === 'truck' ? 'block' : 'none' %>;">
                <label for="truck_assigned">Select Truck <span class="req">*</span></label>
                <select id="truck_assigned" name="truck_assigned" style="width: 100%; padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px;">
                    <option value="">— Select Truck —</option>
                    <% if (locals.trucks) { %>
                        <% trucks.forEach(t => { %>
                            <option value="<%= t.truck_assigned %>" <%= locals.selectedTruck === t.truck_assigned ? 'selected' : '' %>><%= t.truck_assigned %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <!-- Group Select Field -->
            <div class="filter-field" id="group_field" style="flex: 1; min-width: 200px; display: <%= locals.reportTarget === 'group' ? 'block' : 'none' %>;">
                <label for="group_id">Select Group <span class="req">*</span></label>
                <select id="group_id" name="group_id" style="width: 100%; padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px;">
                    <option value="">— Select Group —</option>
                    <% if (locals.groups) { %>
                        <% groups.forEach(g => { %>
                            <option value="<%= g.id %>" <%= locals.selectedGroup && locals.selectedGroup.id == g.id ? 'selected' : '' %>><%= g.name %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <div class="filter-field">
                <label for="start_date">From</label>
                <input type="date" id="start_date" name="start_date" value="<%= startDate %>" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px;">
            </div>
            <div class="filter-field">
                <label for="end_date">To</label>
                <input type="date" id="end_date" name="end_date" value="<%= endDate %>" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 4px;">
            </div>
            <div style="display: flex; gap: 0.35rem; align-items: center; margin-bottom: 2px;">
                <button type="button" class="btn btn-sm btn-outline" style="font-size: 0.72rem; padding: 0.35rem 0.5rem; height: 38px;" onclick="setDatePreset('this_month')" title="Set dates to Current Month">This Month</button>
                <button type="button" class="btn btn-sm btn-outline" style="font-size: 0.72rem; padding: 0.35rem 0.5rem; height: 38px;" onclick="setDatePreset('last_month')" title="Set dates to Previous Month">Last Month</button>
                <button type="button" class="btn btn-sm btn-outline" style="font-size: 0.72rem; padding: 0.35rem 0.5rem; height: 38px;" onclick="setDatePreset('this_quarter')" title="Set dates to Current Quarter">Quarter</button>
                <button type="button" class="btn btn-sm btn-outline" style="font-size: 0.72rem; padding: 0.35rem 0.5rem; height: 38px;" onclick="setDatePreset('ytd')" title="Set dates to Year to Date">YTD</button>
            </div>
            <button type="submit" class="btn btn-primary" style="height: 38px;">
                <i class="fa-solid fa-arrow-right-to-bracket"></i> Load Report
            </button>
        </form>
    </div>
</div>

<script>
    function setDatePreset(type) {
        const now = new Date();
        let start, end = new Date();
        if (type === 'this_month') {
            start = new Date(now.getFullYear(), now.getMonth(), 1);
        } else if (type === 'last_month') {
            start = new Date(now.getFullYear(), now.getMonth() - 1, 1);
            end = new Date(now.getFullYear(), now.getMonth(), 0);
        } else if (type === 'this_quarter') {
            const qMonth = Math.floor(now.getMonth() / 3) * 3;
            start = new Date(now.getFullYear(), qMonth, 1);
        } else if (type === 'ytd') {
            start = new Date(now.getFullYear(), 0, 1);
        }
        const fmt = d => d.toISOString().split('T')[0];
        const startElem = document.getElementById('start_date');
        const endElem = document.getElementById('end_date');
        if (startElem) startElem.value = fmt(start);
        if (endElem) endElem.value = fmt(end);
    }

<script>
    function toggleReportFields(val) {
        const empField = document.getElementById('employee_field');
        const truckField = document.getElementById('truck_field');
        const grpField = document.getElementById('group_field');
        
        empField.style.display = val === 'employee' ? 'block' : 'none';
        truckField.style.display = val === 'truck' ? 'block' : 'none';
        grpField.style.display = val === 'group' ? 'block' : 'none';
        
        // Update required attributes to match selection
        document.getElementById('user_id').required = val === 'employee';
        document.getElementById('truck_assigned').required = val === 'truck';
        document.getElementById('group_id').required = val === 'group';
    }
    // Set initial required states
    document.addEventListener('DOMContentLoaded', () => {
        const targetVal = document.getElementById('report_target').value;
        toggleReportFields(targetVal);
    });
</script>

<!-- ═══ REPORT CONTENTS ═══ -->
<% if (selectedUser) { %>
    
    <%
        const reimbursementExpenses = expenses.filter(e => e.payment_type !== 'Company Card');
        const companyCardExpenses   = expenses.filter(e => e.payment_type === 'Company Card');
        
        const reimbTotal = reimbursementExpenses.reduce((sum, e) => sum + parseFloat(e.total_amount || 0), 0);
        const cardTotal  = companyCardExpenses.reduce((sum, e) => sum + parseFloat(e.total_amount || 0), 0);
    %>

    <div class="admin-page-header" style="margin-bottom: 1.25rem;">
        <div>
            <h2 style="font-size: 1.2rem; font-weight: 700; color: var(--text);">Expenses for <%= selectedUser.first_name %> <%= selectedUser.last_name %></h2>
            <p style="font-size: 0.85rem; color: var(--text-muted);">Cycle: <%= startDate %> to <%= endDate %></p>
        </div>
        <% if ((expenses && expenses.length > 0) || (gasExpenses && gasExpenses.length > 0)) { %>
        <div class="export-btns" style="display: flex; gap: 0.5rem; align-items: center;">
            <button type="button" class="btn btn-sm no-print" onclick="window.print()" title="Print this report" style="background: var(--surface); border: 1px solid var(--border-dark); color: var(--text); padding: 0.4rem 0.75rem; border-radius: 4px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.35rem;">
                <i class="fa-solid fa-print" style="color: var(--primary); font-size: 1.1rem;"></i> Print Report
            </button>
            <a href="/admin/export/pdf/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=all"
               class="btn btn-pdf btn-sm no-print" title="Download Combined PDF Report">
                <i class="fa-solid fa-file-pdf"></i> Export Combined PDF
            </a>
            <a href="/admin/export/excel/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=all"
               class="btn btn-excel btn-sm no-print" title="Download Combined Excel Spreadsheet">
                <i class="fa-solid fa-file-excel"></i> Export Combined Excel
            </a>
            <button type="button" class="btn btn-sm no-print" onclick="openCsvExportModal()" title="Export custom CSV data" style="background: var(--surface); border: 1px solid var(--border-dark); color: var(--text); padding: 0.4rem 0.75rem; border-radius: 4px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.35rem;">
                <i class="fa-solid fa-file-csv" style="color: #2ecc71; font-size: 1.1rem;"></i> Custom CSV Export
            </button>
        </div>
        <% } %>
    </div>

    <!-- SECTION 1: Personal Reimbursement Expenses -->
    <div class="panel" style="margin-bottom: 1.5rem;">
        <div class="panel-header" style="background: var(--primary-light); border-bottom-color: rgba(0,115,234,0.15); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
            <h3 class="panel-title" style="color: var(--primary);">
                <i class="fa-solid fa-hand-holding-dollar"></i> Employee Reimbursement Claims
            </h3>
            <div style="display: flex; gap: 0.4rem; align-items: center;">
                <span style="font-weight: 700; color: var(--primary); font-size: 0.85rem; margin-right: 0.5rem;">
                    Total Reimbursable: $<%= reimbTotal.toFixed(2) %> &nbsp;&middot;&nbsp; <%= reimbursementExpenses.length %> expense(s)
                </span>
                <% if (reimbursementExpenses.length > 0) { %>
                    <a href="/admin/export/pdf/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=reimbursements" class="btn btn-pdf btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; height: auto;" title="Export Reimbursements PDF">
                        <i class="fa-solid fa-file-pdf"></i> PDF
                    </a>
                    <a href="/admin/export/excel/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=reimbursements" class="btn btn-excel btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; height: auto;" title="Export Reimbursements Excel">
                        <i class="fa-solid fa-file-excel"></i> Excel
                    </a>
                <% } %>
            </div>
        </div>
        <div class="panel-body" style="padding: 0;">
            <% if (reimbursementExpenses.length > 0) { %>
                <%- include('partials/reports_table', { tableExpenses: reimbursementExpenses }) %>
            <% } else { %>
                <div class="empty-state" style="padding: 2.5rem 0;">
                    <i class="fa-solid fa-hand-holding-dollar" style="opacity: 0.25;"></i>
                    <p>No reimbursement claims found for this timeline.</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- SECTION 2: Company Credit Card Expenses -->
    <div class="panel" style="margin-bottom: 1.5rem;">
        <div class="panel-header" style="background: var(--border-light); border-bottom-color: var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
            <h3 class="panel-title" style="color: var(--text);">
                <i class="fa-solid fa-credit-card"></i> Company Credit Card Expenses
            </h3>
            <div style="display: flex; gap: 0.4rem; align-items: center;">
                <span style="font-weight: 700; color: var(--text); font-size: 0.85rem; margin-right: 0.5rem;">
                    Total Company Card Cost: $<%= cardTotal.toFixed(2) %> &nbsp;&middot;&nbsp; <%= companyCardExpenses.length %> expense(s)
                </span>
                <% if (companyCardExpenses.length > 0) { %>
                    <a href="/admin/export/pdf/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=cards" class="btn btn-pdf btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; height: auto;" title="Export Company Card PDF">
                        <i class="fa-solid fa-file-pdf"></i> PDF
                    </a>
                    <a href="/admin/export/excel/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=cards" class="btn btn-excel btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; height: auto;" title="Export Company Card Excel">
                        <i class="fa-solid fa-file-excel"></i> Excel
                    </a>
                <% } %>
            </div>
        </div>
        <div class="panel-body" style="padding: 0;">
            <% if (companyCardExpenses.length > 0) { %>
                <%- include('partials/reports_table', { tableExpenses: companyCardExpenses }) %>
            <% } else { %>
                <div class="empty-state" style="padding: 2.5rem 0;">
                    <i class="fa-solid fa-credit-card" style="opacity: 0.25;"></i>
                    <p>No company credit card expenses found for this timeline.</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- SECTION 3: Gas Card Expenses -->
    <%
        const gasTotal = gasExpenses.reduce((sum, e) => sum + parseFloat(e.total_amount || 0), 0);
    %>
    <div class="panel" style="margin-bottom: 1.5rem;">
        <div class="panel-header" style="background: rgba(230,126,34,0.08); border-bottom-color: rgba(230,126,34,0.2); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
            <h3 class="panel-title" style="color: #e67e22;">
                <i class="fa-solid fa-gas-pump"></i> Gas Card Expenses
            </h3>
            <div style="display: flex; gap: 0.4rem; align-items: center;">
                <span style="font-weight: 700; color: #e67e22; font-size: 0.85rem; margin-right: 0.5rem;">
                    Total Gas Cost: $<%= gasTotal.toFixed(2) %> &nbsp;&middot;&nbsp; <%= gasExpenses.length %> expense(s)
                </span>
                <% if (gasExpenses.length > 0) { %>
                    <a href="/admin/export/pdf/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=gas" class="btn btn-pdf btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; height: auto; background-color:#e67e22; border-color:#e67e22;" title="Export Gas PDF">
                        <i class="fa-solid fa-file-pdf"></i> PDF
                    </a>
                    <a href="/admin/export/excel/<%= selectedUser.id %>?start_date=<%= startDate %>&end_date=<%= endDate %>&type=gas" class="btn btn-excel btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; height: auto; background-color:#27ae60; border-color:#27ae60;" title="Export Gas Excel">
                        <i class="fa-solid fa-file-excel"></i> Excel
                    </a>
                <% } %>
            </div>
        </div>
        <div class="panel-body" style="padding: 0;">
            <% if (gasExpenses.length > 0) { %>
                <!-- Gas Card & Truck Analytics Summary -->
                <% if (locals.gasAnalytics && gasAnalytics.length > 0) { %>
                    <div style="padding: 1.25rem; background: var(--surface-light); border-bottom: 1px solid var(--border); border-radius: var(--radius-sm) var(--radius-sm) 0 0;">
                        <h4 style="margin: 0 0 0.75rem 0; font-size: 0.95rem; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 0.4rem;">
                            <i class="fa-solid fa-chart-bar" style="color: #e67e22;"></i> Card &amp; Truck Analytics Summary for <%= selectedUser.first_name %>
                        </h4>
                        <div class="table-responsive" style="border: 1px solid var(--border); border-radius: 6px; background: #fff; margin-bottom: 1rem;">
                            <table class="table" style="margin-bottom: 0;">
                                <thead>
                                    <tr style="background: var(--background-light);">
                                        <th>Card Info</th>
                                        <th>Assigned Truck</th>
                                        <th style="text-align: right;">Fillups</th>
                                        <th style="text-align: right;">Total Spent</th>
                                        <th style="text-align: right;">Total Liters</th>
                                        <th style="text-align: right;">Last Odo</th>
                                        <th style="text-align: right;">Dist. Travelled</th>
                                        <th style="text-align: right;">Consumption</th>
                                        <th style="text-align: right;">Avg. Dist between Fillups</th>
                                        <th style="text-align: right;">Avg. Hours between Fillups</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% gasAnalytics.forEach(c => { %>
                                        <tr>
                                            <td>
                                                <div style="font-weight: 600; font-size: 0.85rem;">•••• <%= c.card_number.slice(-4) %></div>
                                                <div style="font-size: 0.72rem; color: var(--text-muted);"><%= c.card_type %></div>
                                            </td>
                                            <td><strong><%= c.truck_assigned || 'None / Personal' %></strong></td>
                                            <td style="text-align: right;"><%= c.fillups_count %></td>
                                            <td style="text-align: right; font-weight: 600; color: var(--text);">$<%= c.total_amount.toFixed(2) %></td>
                                            <td style="text-align: right;"><%= c.total_liters.toFixed(1) %> L</td>
                                            <td style="text-align: right;"><%= c.last_odo ? c.last_odo.toLocaleString() + ' km' : '—' %></td>
                                            <td style="text-align: right;"><%= c.total_distance ? c.total_distance.toLocaleString() + ' km' : '—' %></td>
                                            <td style="text-align: right; font-weight: 600; color: var(--primary);">
                                                <%= c.consumption_rate ? c.consumption_rate.toFixed(1) + ' L/100km' : '—' %>
                                            </td>
                                            <td style="text-align: right;"><%= c.avg_distance ? c.avg_distance.toLocaleString() + ' km' : '—' %></td>
                                            <td style="text-align: right;"><%= c.avg_hours ? c.avg_hours + ' hrs' : '—' %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } %>

                <div class="table-responsive">
                    <table class="table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Store/Merchant</th>
                                <th>Origin</th>
                                <th>Card Number</th>
                                <th>Job #</th>
                                <th>Liters</th>
                                <th style="text-align: right;">Net ($)</th>
                                <th style="text-align: right;">GST ($)</th>
                                <th style="text-align: right;">Total ($)</th>
                                <th>Receipt</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% gasExpenses.forEach(exp => { %>
                                <tr>
                                    <td><%= typeof exp.date === 'string' ? exp.date.split('T')[0] : '' %></td>
                                    <td><strong><%= exp.store_name %></strong></td>
                                    <td>
                                        <span class="badge" style="background: rgba(230, 126, 34, 0.1); color: #e67e22; border: 1px solid rgba(230, 126, 34, 0.25); font-size: 0.72rem; padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 600;"><i class="fa-solid fa-gas-pump"></i> Gas Card</span>
                                    </td>
                                    <td><code style="font-size:0.8rem; background:var(--bg-light); padding:0.1rem 0.3rem; border-radius:3px;">****<%= exp.card_number ? exp.card_number.slice(-4) : 'N/A' %></code></td>
                                    <td>
                                        <span style="font-weight: 600;"><%= exp.job_number || 'N/A' %></span>
                                        <% if (exp.job_number && typeof pendingJobsMap !== 'undefined' && pendingJobsMap[exp.job_number.trim().toUpperCase()]) { %>
                                            <div style="margin-top: 0.35rem;">
                                                <form action="/admin/jobnumbers/confirm/<%= pendingJobsMap[exp.job_number.trim().toUpperCase()] %>" method="POST" style="display: inline;">
                                                    <button type="submit" class="btn btn-sm" style="background: #2ecc71; color: #fff; border: none; padding: 0.2rem 0.45rem; border-radius: 4px; font-weight: 600; cursor: pointer; font-size: 0.65rem; display: inline-flex; align-items: center; gap: 0.2rem; height: auto;" title="Accept and Activate Job Number">
                                                        <i class="fa-solid fa-check" style="font-size: 0.6rem;"></i> Accept Job
                                                    </button>
                                                </form>
                                            </div>
                                        <% } %>
                                    </td>
                                    <td><%= exp.liters_in_tank %>L</td>
                                    <td style="text-align: right;">$<%= parseFloat(exp.net_amount).toFixed(2) %></td>
                                    <td style="text-align: right;">$<%= parseFloat(exp.tax_amount).toFixed(2) %></td>
                                    <td style="text-align: right; font-weight: 600;">$<%= parseFloat(exp.total_amount).toFixed(2) %></td>
                                    <td>
                                        <% if (exp.receipt_photo_path) { %>
                                            <div class="receipt-thumbnail-container">
                                                <img src="<%= exp.receipt_photo_path %>" class="receipt-thumbnail" onclick="viewReceipt('<%= exp.receipt_photo_path %>')" alt="Receipt" title="Click to enlarge" />
                                            </div>
                                        <% } else { %>
                                            <span style="color: var(--text-light);">—</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state" style="padding: 2.5rem 0;">
                    <i class="fa-solid fa-gas-pump" style="opacity: 0.25;"></i>
                    <p>No gas card expenses found for this timeline.</p>
                </div>
            <% } %>
        </div>
    </div>

<% } else if (locals.selectedTruck) { %>
    <div class="admin-page-header" style="margin-bottom: 1.25rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h2 style="font-size: 1.2rem; font-weight: 700; color: var(--text);">Fuel &amp; Odometer Analytics for <%= locals.selectedTruck %></h2>
            <p style="font-size: 0.85rem; color: var(--text-muted);">Cycle: <%= startDate %> to <%= endDate %></p>
        </div>
        <div class="export-btns no-print" style="display: flex; gap: 0.5rem; align-items: center;">
