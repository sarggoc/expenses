<%- include('../partials/header') %>

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title"><i class="fa-solid fa-users"></i> Users <span>Management</span></h1>
        <p class="admin-page-sub">View and manage system users, card references, roles, and spending limits.</p>
    </div>
</div>

<% if (error) { %>
<div class="alert alert-error">
    <i class="fa-solid fa-circle-exclamation"></i><span><%= decodeURIComponent(error) %></span>
</div>
<% } %>
<% if (success) { %>
<div class="alert alert-success">
    <i class="fa-solid fa-circle-check"></i><span><%= decodeURIComponent(success) %></span>
</div>
<% } %>

<!-- ═══ ACTIVE USERS TABLE ═══ -->
<div class="panel" style="margin-bottom: 2rem;">
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h2 class="panel-title"><i class="fa-solid fa-address-book"></i> Active Users</h2>
        <a href="/admin/users/add" class="btn btn-accent btn-sm">
            <i class="fa-solid fa-user-plus"></i> Add New User
        </a>
    </div>
    <div class="panel-body" style="padding: 0;">
        <div class="table-responsive">
            <table class="table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="padding: 0.85rem 1rem; text-align: left;">User</th>
                        <th style="padding: 0.85rem 1rem; text-align: left;">Role</th>
                        <th style="padding: 0.85rem 1rem; text-align: left;">Card Ref</th>
                        <th style="padding: 0.85rem 1rem; text-align: left;">Limits (CC / Reimb)</th>
                        <th style="padding: 0.85rem 1rem; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr style="border-bottom: 1px solid var(--border-light);">
                            <td style="padding: 0.85rem 1rem;">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <div style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #0073EA, #00C875); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 800; font-size: 0.85rem; overflow: hidden; flex-shrink: 0; border: 2px solid var(--primary-light);">
                                        <% if (u.profile_photo_path) { %>
                                            <img src="<%= u.profile_photo_path %>" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;" />
                                        <% } else { %>
                                            <%= u.first_name.charAt(0).toUpperCase() %><%= u.last_name.charAt(0).toUpperCase() %>
                                        <% } %>
                                    </div>
                                    <div>
                                        <div style="font-weight: 600; color: var(--text);"><%= u.first_name %> <%= u.last_name %></div>
                                        <div style="font-size: 0.75rem; color: var(--text-muted);">
                                            @<%= u.username %> • <%= u.email %>
                                            <% if (u.division_name) { %>
                                                • <span style="font-weight: 600; color: var(--primary);"><%= u.division_name %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td style="padding: 0.85rem 1rem;">
                                <span class="badge badge-<%= u.role %>"><%= u.role === 'pm' ? 'Project Manager' : u.role %></span>
                            </td>
                            <td style="padding: 0.85rem 1rem;">
                                <span class="card-id-badge"><i class="fa-solid fa-credit-card"></i> <%= u.card_last_digits %></span>
                            </td>
                            <td style="padding: 0.85rem 1rem; font-weight: 600;">
                                <div style="color: var(--sidebar-bg); font-size: 0.82rem;">CC: <%= u.spending_limit ? '$' + parseFloat(u.spending_limit).toFixed(2) : 'Global Default' %></div>
                                <div style="color: var(--accent-dark); font-size: 0.76rem;">Reimb: <%= u.reimbursement_cap ? '$' + parseFloat(u.reimbursement_cap).toFixed(2) : 'Global Default' %></div>
                            </td>
                            <td style="padding: 0.85rem 1rem; text-align: center;">
                                <div style="display: flex; gap: 0.4rem; justify-content: center;">
                                    <button class="btn btn-sm btn-outline" onclick="openAdminUserEditModal(<%= JSON.stringify(u) %>)">
                                        <i class="fa-solid fa-pen-to-square"></i> Edit
                                    </button>
                                    <% if (u.id !== user.id) { %>
                                        <form action="/admin/users/delete/<%= u.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete user \'<%= u.first_name %> <%= u.last_name %>\'?');" style="display: inline;">
                                            <button type="submit" class="btn btn-sm" style="background: var(--danger-light); color: var(--danger); border: none;">
                                                <i class="fa-solid fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Admin User Edit Modal -->
<div id="adminUserEditModal" class="modal" role="dialog" aria-modal="true" aria-label="Edit User">
    <button class="modal-close" onclick="closeAdminUserEditModal()"><i class="fa-solid fa-xmark"></i></button>
    <div class="panel" style="width: 100%; max-width: 480px; background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow-lg);">
        <div class="panel-header">
            <h2 class="panel-title"><i class="fa-solid fa-user-pen"></i> Edit User Details</h2>
        </div>
        <div class="panel-body">
            <form id="adminUserEditForm" action="/admin/users/edit" method="POST" autocomplete="off">
                <input type="hidden" id="edit_user_id" name="id">
                
                <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                    <div class="form-group">
                        <label for="edit_first_name">First Name <span class="req">*</span></label>
                        <input type="text" id="edit_first_name" name="first_name" required>
                    </div>
                    <div class="form-group">
                        <label for="edit_last_name">Last Name <span class="req">*</span></label>
                        <input type="text" id="edit_last_name" name="last_name" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="edit_username">Username <span class="req">*</span></label>
                    <input type="text" id="edit_username" name="username" required>
                </div>

                <div class="form-group">
                    <label for="edit_email">Email Address <span class="req">*</span></label>
                    <input type="email" id="edit_email" name="email" required>
                </div>

                <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                    <div class="form-group">
                        <label for="edit_card_last_digits">Card Last 4 <span style="color:var(--text-light);font-weight:400;"> (optional)</span></label>
                        <input type="text" id="edit_card_last_digits" name="card_last_digits" maxLength="4">
                    </div>
                    <div class="form-group">
                        <label for="edit_role">Role <span class="req">*</span></label>
                        <select id="edit_role" name="role" required>
                            <option value="user">User</option>
                            <option value="pm">Project Manager</option>
                            <option value="approver">Approver</option>
                            <option value="accounting">Accounting</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="edit_division_id">Division <span style="color:var(--text-light);font-weight:400;"> (optional)</span></label>
                    <select id="edit_division_id" name="division_id">
                        <option value="">— No Division —</option>
                        <% (locals.divisions || []).forEach(d => { %>
                            <option value="<%= d.id %>"><%= d.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="edit_spending_limit">Credit Card Limit ($) <span style="color:var(--text-light);font-weight:400;"> (leave blank for default)</span></label>
                    <input type="number" id="edit_spending_limit" name="spending_limit" step="0.01">
                </div>

                <div class="form-group">
                    <label for="edit_reimbursement_cap">Reimbursement Cap ($) <span style="color:var(--text-light);font-weight:400;"> (leave blank for default)</span></label>
                    <input type="number" id="edit_reimbursement_cap" name="reimbursement_cap" step="0.01">
                </div>

                <div class="form-group">
                    <label for="edit_password">Reset Password <span style="color:var(--text-light);font-weight:400;"> (leave blank to keep current)</span></label>
                    <input type="password" id="edit_password" name="password" placeholder="••••••••">
                </div>

                <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
                    <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeAdminUserEditModal()">Cancel</button>
                    <button type="submit" class="btn btn-accent" style="flex: 2;">
                        <i class="fa-solid fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const adminUserEditModal = document.getElementById("adminUserEditModal");
    window.openAdminUserEditModal = function(user) {
        document.getElementById("edit_user_id").value = user.id;
        document.getElementById("edit_first_name").value = user.first_name;
        document.getElementById("edit_last_name").value = user.last_name;
        document.getElementById("edit_username").value = user.username;
        document.getElementById("edit_email").value = user.email;
        document.getElementById("edit_card_last_digits").value = user.card_last_digits;
        document.getElementById("edit_role").value = user.role;
        document.getElementById("edit_division_id").value = user.division_id || '';
        document.getElementById("edit_spending_limit").value = user.spending_limit || '';
        document.getElementById("edit_reimbursement_cap").value = user.reimbursement_cap || '';
        document.getElementById("edit_password").value = '';
        
        if (adminUserEditModal) {
            adminUserEditModal.classList.add("open");
            document.body.style.overflow = "hidden";
        }
    };
    window.closeAdminUserEditModal = function() {
        if (adminUserEditModal) {
            adminUserEditModal.classList.remove("open");
            document.body.style.overflow = "";
        }
    };
    
    // Close modal on escape
    document.addEventListener("keydown", e => {
        if (e.key === "Escape") {
            closeAdminUserEditModal();
        }
    });
</script>

<%- include('../partials/footer') %>
