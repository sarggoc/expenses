<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Sargtech Expenses</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
</head>
<body>
<div class="auth-wrap">
    <div class="auth-card" style="text-align: center; border-top-color: var(--danger);">
        <div class="auth-logo">
            <div class="icon" style="background: var(--danger-light);"><i class="fa-solid fa-triangle-exclamation" style="color: var(--danger);"></i></div>
            <h1 style="color: var(--danger);"><%= title %></h1>
            <p><%= message %></p>
        </div>
        <a href="/" class="btn btn-primary btn-full"><i class="fa-solid fa-house"></i> Back to Home</a>
    </div>
</div>
</body>
</html>
