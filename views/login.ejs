<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Sargtech Expenses</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script>
        (function() {
            const t = localStorage.getItem('sargtech-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
</head>
<body>

<div class="auth-page">
    <div class="auth-card">

        <!-- Logo -->
        <div class="auth-logo">
            <% if (locals.settings && locals.settings.custom_logo_path) { %>
                <img src="<%= locals.settings.custom_logo_path %>" alt="Logo" class="custom-logo-img" style="max-height: 52px; max-width: 200px; object-fit: contain; border-radius: 6px; margin: 0 auto 1.5rem auto; display: block;">
            <% } else { %>
                <div class="auth-logo-icon"><i class="fa-solid fa-wallet"></i></div>
                <div class="auth-logo-text">
                    <% 
                        let text = (locals.settings && locals.settings.custom_logo_text) ? locals.settings.custom_logo_text : 'SargTech Expenses';
                        let parts = text.split(' ');
                        let brand = parts[0] || 'SargTech';
                        let sub = parts.slice(1).join(' ') || 'Expenses';
                    %>
                    <%= brand %><span><%= sub %></span>
                </div>
            <% } %>
        </div>

        <!-- Tabs -->
        <div class="auth-tabs">
            <a href="/login"    class="auth-tab <%= mode === 'login'    ? 'active' : '' %>"><i class="fa-solid fa-lock"></i> Sign In</a>
            <a href="/register" class="auth-tab <%= mode === 'register' ? 'active' : '' %>"><i class="fa-solid fa-user-plus"></i> Register</a>
        </div>

        <% if (error) { %>
        <div class="alert alert-error">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span><%= error %></span>
        </div>
        <% } %>

        <% if (success) { %>
        <div class="alert alert-success">
            <i class="fa-solid fa-circle-check"></i>
            <span><%= success %></span>
        </div>
        <% } %>

        <% if (mode === 'register') { %>
        <form action="/register" method="POST" autocomplete="on">
            <div class="form-row">
                <div class="form-group">
                    <label for="first_name">First Name <span class="req">*</span></label>
                    <input type="text" id="first_name" name="first_name" required autocomplete="given-name" placeholder="John">
                </div>
                <div class="form-group">
                    <label for="last_name">Last Name <span class="req">*</span></label>
                    <input type="text" id="last_name" name="last_name" required autocomplete="family-name" placeholder="Doe">
                </div>
            </div>
            <div class="form-group">
                <label for="email">Email Address <span class="req">*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="john.doe@company.com">
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="username">Username <span class="req">*</span></label>
                    <input type="text" id="username" name="username" required autocomplete="username" placeholder="johndoe">
                </div>
                <div class="form-group">
                    <label for="card_last_digits">Card Last 4 <span style="font-weight:400; color:var(--text-light);">(optional)</span></label>
                    <input type="text" id="card_last_digits" name="card_last_digits"
                           inputmode="numeric" pattern="[0-9]{4}" maxlength="4" placeholder="None">
                </div>
            </div>
            <div class="form-group">
                <label for="password">Password <span class="req">*</span></label>
                <input type="password" id="password" name="password" required autocomplete="new-password" placeholder="••••••••">
            </div>
            <button type="submit" class="btn btn-primary btn-full" style="margin-top:.5rem;">
                <i class="fa-solid fa-user-plus"></i> Create Account
            </button>
        </form>

        <% } else { %>
        <form action="/login" method="POST" autocomplete="on">
            <div class="form-group">
                <label for="username">Username or Email <span class="req">*</span></label>
                <input type="text" id="username" name="username" required autocomplete="username" placeholder="johndoe">
            </div>
            <div class="form-group">
                <label for="password">Password <span class="req">*</span></label>
                <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••">
            </div>
            <button type="submit" class="btn btn-primary btn-full" style="margin-top:.5rem;">
                <i class="fa-solid fa-lock"></i> Sign In Securely
            </button>
            <button type="button" class="btn btn-outline btn-full" style="margin-top: 0.5rem; display: flex; align-items: center; justify-content: center; gap: 0.4rem;" onclick="loginWithBiometrics()">
                <i class="fa-solid fa-fingerprint" style="color: #8e44ad;"></i> FaceID / Fingerprint Unlock
            </button>
        </form>
        <% } %>

    </div>
</div>

<script src="/js/app.js"></script>
</body>
</html>
